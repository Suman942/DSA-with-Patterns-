fun main() {
    val landStartTime = intArrayOf(2,8)
    val landDuration = intArrayOf(4,1)
    val waterStartTime = intArrayOf(6)
    val waterDuration = intArrayOf(3)
 	var minimum = Int.MAX_VALUE
    for(i in landStartTime.indices){
        for(j in waterStartTime.indices){
            // land -> water
            val landFinish = landStartTime[i] + landDuration[i] // 2 + 4 = 6, 8+1 = 9
            val waterOpen =  maxOf(landFinish,waterStartTime[j])// 6,6 = 6,(9,6) = 9
            val finish1 = waterDuration[j] + waterOpen // 6 + 3 = 9, 3+9= 12

            println("landFinish$:$landFinish")
         	println("waterOpen$:$waterOpen")
			println("finish1$:$finish1")
            println()
            
            //water -> land
            val waterFinish = waterStartTime[j] + waterDuration[j] // 6+3=9, 9
            val landOpen= maxOf(waterFinish,landStartTime[i])// (9,2) = 9 , 9
            val finish2 = landOpen + landDuration[i]// 9+4 = 13, 9+1 = 10
			
			println("waterFinish$:$waterFinish")
         	println("landOpen$:$landOpen")
			println("finish2$:$finish2")
            
           println()
			minimum = minOf(minimum,finish1,finish2)
        }

    }
    
    println(minimum)
}
