fun main() {
    val hour = 12
 	val minutes = 30
    
    var m = minutes 
	var mAngle = m * 6
	println("minutes: $mAngle")
    
    var h = hour % 12
	println("h: $h")

	var hAngle = h * 30 + m * 0.5
	println("hour: $hAngle")
    
    val diff = kotlin.math.abs(hAngle - mAngle)
    println("diff: $diff")
	
	println("result: ${minOf(diff,360-diff)}")
}
