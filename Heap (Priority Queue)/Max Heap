import java.util.PriorityQueue
fun main() {
 	val nums = intArrayOf(10, 5, 20, 3, 8)
	val heap = PriorityQueue<Int>(compareByDescending{it})
    
    for(num in nums){
        heap.add(num)
    }
    
    while(heap.isNotEmpty()){
        println(heap.poll())
    }
}
