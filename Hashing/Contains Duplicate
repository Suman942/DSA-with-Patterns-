🧠 Problem: Contains Duplicate
👉 What it says (simple English):

You are given an array of numbers.

👉 Check if any number appears more than once

If yes → return true
If no → return false

fun main() {
    val arr = intArrayOf(2,9,11,7,1)
    val set = mutableSetOf<Int>()
    
    for(i in arr.indices){
        // if exist inside the set return true
        if(set.contains(arr[i])){
            println(true)
            return
        }
        // store value inside the set
        set.add(arr[i])
    }
    print(false)
}
