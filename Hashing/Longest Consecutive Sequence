Given an unsorted array of integers, find the length of the longest consecutive elements sequence.

Input: [100, 4, 200, 1, 3, 2]
Output: 4

Explanation:
Sequence → [1, 2, 3, 4]

Solution:
fun main() {
	val nums = intArrayOf(100, 4, 200, 1, 3, 2)
    
    val map = mutableMapOf<Int,Boolean>()
    var max = 0
    for(num in nums){
      map[num] = false
    }
    
    for(num in nums){
        var currentLen = 1
        
        // forward direction
        var nextElement = num + 1
        while(map.containsKey(nextElement) && map[nextElement] == false){
            currentLen++
            map[nextElement] = true
            nextElement++
          
        }
        
        // previous direction
        var prevElement = num - 1
        while(map.containsKey(prevElement) && map[prevElement] == false){
            currentLen++
            map[prevElement] = true
            prevElement--
        }
        max = maxOf(max,currentLen)
    }
   println(max)
}
