fun main() {
	val str = "()[]{]"
      
  print(solution(str))
}

fun solution(str:String) : Boolean{
        val stack = ArrayDeque<Char>()

     val map = mapOf(
    ')' to '(',
    '}' to '{',
    ']' to '[')
    
    for(s in str){
        when(s){
            '(','{','[' -> stack.addLast(s)
			else -> {
                if(stack.isEmpty()) {return false}
               val top = stack.removeLast()
               if(top != map[s]){
                   return false
               }
            }
        }
    }
    return stack.isEmpty()
}
