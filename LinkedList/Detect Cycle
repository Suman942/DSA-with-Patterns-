fun main() {
	val l0 = ListNode(0)
    val l1 = ListNode(1)
	val l2 = ListNode(2)
    val l3 = ListNode(3)
	val l4 = ListNode(4)

    l0.next = l1
    l1.next = l2
    l2.next = l3
    l3.next = l4
	l4.next =l3
    var result = false
    var slow:ListNode? = l0
	var fast:ListNode?= l0
	while(fast != null && fast.next != null){
        
        slow = slow?.next
        fast = fast?.next?.next
		if(slow == fast){
            result = true
            break
        }
    }
	println(result)
}

class ListNode(val value:Int){
    var next:ListNode?=null
}
