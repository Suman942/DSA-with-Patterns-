class Solution {
    fun check(nums: IntArray): Boolean {
 //       val nums = intArrayOf(2,1,3)
        var drop = 0
        for(i in 0 until nums.size){
            /*compare each element
            2 > 1 -> drop 1
            1 > 3 -> fine
            3 > 2 -> drop 2
             */
            if(nums[i] > nums[(i+1) % nums.size]){
                    drop++
            }
        }

        return drop <= 1 // if drop is less than equal to 1 its sorted and rotated
    }
}
