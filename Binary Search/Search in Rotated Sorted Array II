fun main() {
 val nums = intArrayOf(1,0,1,1,1)
 val target = 0
    val n = nums.size
    var left = 0
    var right = n - 1

    while(left <= right){
        // find mid
        val mid = left + (right - left) / 2
        
        // return if target found
        if(nums[mid] == target){
            println(true)
            break
        }
        
        // remove duplicated if exist
        if(nums[left] == nums[mid] && nums[mid] == nums[right]){
            left++
            right--
            continue
        }
        
        // is left half sorted
        if(nums[left] <= nums[mid]){
            // target lie within left to mid
            if(nums[left] <= target && target < nums[mid]){
                right = mid -1
            }else{
                left = mid + 1
            }
        }else{
            // is right half sorted
            // target lie within mid to right
            if(nums[mid] < target && target <= nums[right]){
                left = mid + 1
            }else{
                right = mid - 1
            }
        }
    }
}
