Given a sorted array of distinct integers and a target value, return the index if the target is found. If not, return the index where it would be if it were inserted in order.

You must write an algorithm with O(log n) runtime complexity.

Example 1:

Input: nums = [1,3,5,6], target = 5
Output: 2
Example 2:

Input: nums = [1,3,5,6], target = 2
Output: 1

1. Itertive approach
class Solution {
    fun searchInsert(nums: IntArray, target: Int): Int {
      /*
        find the mid value
        if value is greater then target
            -> move to the right half
        if value is smaller than target
            -> move to left half
        if equal return   

        if none of the condition is true means target do not exist then return the position when the target should be i.e low
       */ 

       var low = 0
       var high = nums.size - 1
       while(low <= high){
         val mid = low + (high - low)/2
            if(nums[mid] == target){
                return mid
            }else if(nums[mid] < target){
                 low = mid + 1
            }else{
                high = mid - 1
            }
       } 
       return low
    }
}


2. Recursive approach
class Solution {
    fun searchInsert(nums: IntArray, target: Int): Int {
      /*
        find the mid value
        if value is greater then target
            -> move to the right half
        if value is smaller than target
            -> move to left half
        if equal return   
       */ 

       var low = 0
       var high = nums.size - 1
        return bs(low,high,nums,target)
    }

    fun bs(low:Int,high:Int,nums:IntArray,target:Int):Int{
        if(low > high) return low
         val mid = low + (high - low)/2
            if(nums[mid] == target){
                return mid
            }else if(nums[mid] < target){
               return  bs(mid+1,high,nums,target)
            }else{
               return bs(low,mid-1,nums,target)
            }

    }
}
