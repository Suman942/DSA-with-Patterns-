var idx = -1
fun main() {
    
	val root = listOf(1,2,-1,-1,3,4,-1,-1,5,-1,-1)
    val result = mutableListOf<Int>()
   val node = buildTree(root,result)
    println("result: $result")
    
    // max depth
   val op =  maxDepth(node)
   println(op)
}
// calculate the depth 
//1. calculate the left subtree height
//2. calculate the right subtree height
//3. max of left subtree and right subtree
//4. add +1 to the max
fun maxDepth(rootNode:TreeNode?):Int{
    if(rootNode == null) return 0
    println("rootNode: ${rootNode.data}") 
    val left = maxDepth(rootNode.left) 
    println("left:${rootNode.left?.data} 
    val right = maxDepth(rootNode.right) 
    println("right:${rootNode.right?.data} -> $right")
    println()
    println()
    return maxOf(left,right) + 1
}

// build your tree
fun buildTree(root:List<Int>,result:MutableList<Int>) : TreeNode?{
    idx++
    if(root[idx] == -1){
        return null
    }
    // add
    result.add(root[idx])
    // new node
    val node = TreeNode(root[idx])
    // left subtree
    node.left = buildTree(root,result)
  
    // right subtree
    node.right = buildTree(root,result)
    return node
}

class TreeNode(val data:Int){
    var left:TreeNode?=null
    var right:TreeNode?=null 
}
