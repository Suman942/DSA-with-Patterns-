// find height + optimal
fun height(node:TreeNode?) : Int{
    if(node == null) return 0
    val left = height(node.left)
    val right = height(node.right)
    diam = maxOf((left + right),diam) -> calcute the height of current node and storing the max diameter
    return maxOf(left,right) + 1
}


/* find diameter
Condition: 1. May pass through root node 2. May not Pass through root node
Approach:
1. find left diam from root = lDiam
2. find right diam from root = rDiam
3. find height of root = lH + rH
*/
fun diameter(node:TreeNode?):Int{
    if(node == null) return 0
    val lDiameter = diameter(node.left) // left diam
    val rDiameter = diameter(node.right) // right diam
    val currentDiameter =  height(node.left) + height(node.right) // height
    
    return maxOf(lDiameter,rDiameter,currentDiameter)
}


// build your tree
fun buildTree(root:List<Int>) : TreeNode?{
    idx++
    if(root[idx] == -1){
        return null
    }
   
    // new node
    val node = TreeNode(root[idx])
    // left subtree
    node.left = buildTree(root)
  
    // right subtree
    node.right = buildTree(root)
    return node
}

class TreeNode(val data:Int){
    var left:TreeNode?=null
    var right:TreeNode?=null 
}
