var idx = -1
fun main() {
    
	val root = listOf(1,2,-1,-1,3,4,-1,-1,5,-1,-1)
    val result = mutableListOf<Int>()
    val node = buildTree(root,result)
    println("result: ${node?.data}")
    println()
    preOrder(node)
}

fun buildTree(root:List<Int>,result:MutableList<Int>) : TreeNode?{
    idx++
    if(root[idx] == -1){
        return null
    }
    result.add(root[idx])
    val node = TreeNode(root[idx])
    node.left = buildTree(root,result)
    node.right = buildTree(root,result)
    return node
}

class TreeNode(val data:Int){
    var left:TreeNode?=null
    var right:TreeNode?=null 
}

fun preOrder(root:TreeNode?){
    if(root == null) return
    
    println(root.data)
    
    preOrder(root.left)
    preOrder(root.right)
}
