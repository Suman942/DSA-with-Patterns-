var idx = -1
fun main() {
    val root = listOf(1,2,-1,-1,3,4,-1,-1,5,-1,-1) 
	val node = buildTree(root)
    bottomView(node) // handles top view
}

fun bottomView(node:TreeNode?){
    val queue = ArrayDeque<Pair<TreeNode?,Int>>() // Pair<Node,HD>  (Horizontal Distance)
    val map = mutableMapOf<Int,Int>() // <HD and Node value>
    queue.addLast(Pair(node,0))
    while(queue.isNotEmpty()){
        val pair = queue.removeFirst()
        val currNode = pair.first
        println("level:${currNode?.data}")
        val currHD = pair.second
        println("currHD:${currHD}")
        
 
            currNode?.let{
       	 	map[currHD] = it.data
            }
    	

        currNode?.left?.let{
            queue.addLast(Pair(it,currHD - 1))
        }
        currNode?.right?.let{
            queue.addLast(Pair(it,currHD + 1))
        }
    }
    
    println(map.toSortedMap().values.toList())
}

fun buildTree(root:List<Int>):TreeNode?{
    idx++// 0,1
    if(root[idx] == -1){return null}
//   	print(root[idx])
    val node = TreeNode(root[idx]) // 1,2
    
    node.left = buildTree(root)//1.left = 
    node.right = buildTree(root)
    
    return node
}
class TreeNode(val data:Int){
    var left:TreeNode?=null
    var right:TreeNode?=null
}
