var idx = -1
fun main() {
	val root = listOf(1,2,-1,-1,3,4,-1,-1,5,-1,-1)
    val result = mutableListOf<Int>()
   val head = buildTree(root,result)
// all value of kth level
   val k = 3
    kthLevel(head,k)
}
fun kthLevel(root:TreeNode?,k:Int){
    
    if(root == null) return
    
    if(k == 1){
        println(root.data)
        return
    }
    kthLevel(root.left,k-1)
    kthLevel(root.right, k - 1)
}
fun buildTree(root:List<Int>,result:MutableList<Int>) : TreeNode?{
    idx++
    if(root[idx] == -1){
        return null
    }
    // add
    result.add(root[idx])
    // new node
    val node = TreeNode(root[idx])
    // left subtree
    node.left = buildTree(root,result)
    // right subtree
    node.right = buildTree(root,result)
    return node
}

class TreeNode(val data:Int){
    var left:TreeNode?=null
    var right:TreeNode?=null 
}
