var idx = -1
fun main() {
    
	val root = listOf(1,2,-1,-1,3,4,-1,-1,5,-1,-1)
    val result = mutableListOf<Int>()
   
    println("before conversion")
   	val node =  buildTree(root,result)
	  preOrder(node)
    
    sumTree(node)
    
    println("after conversion")
	  preOrder(node)

}

fun sumTree(node:TreeNode?) : Int{
    if(node == null) return 0
    
    val left = sumTree(node.left)
    
    val right = sumTree(node.right)

	  node.data += left + right 
    return node.data
}

fun preOrder(root:TreeNode?){
    if(root == null) return
    
    println(root.data)
    
    preOrder(root.left)
    preOrder(root.right)
}

fun buildTree(root:List<Int>,result:MutableList<Int>) : TreeNode?{
    idx++
    if(root[idx] == -1){
        return null
    }
    // add
    result.add(root[idx])
    // new node
    val node = TreeNode(root[idx])
    // left subtree
    node.left = buildTree(root,result)
    // right subtree
    node.right = buildTree(root,result)
    return node
}

class TreeNode(var data:Int){
    var left:TreeNode?=null
    var right:TreeNode?=null 
}
