Note: In BST 
-> left of root is small than root
-> right of root is greater than root
-> inorder traversal is always sorted

fun main() {
 val root = intArrayOf(3,2,1,5,4,6)
 val node = buildBST(root)
  // traverse in order
 inorder(node)
// search if value exist
search(node,5)
}

fun search(node:Node?,key:Int):Boolean{
    if(node == null) return false
    if(node.data == key){
        return true
    }
    return if(key < node.data){
        search(node.left,key)
    }else{
        search(node.right,key)
    }
    
}

fun buildBST(arr:IntArray): Node?{
    var root:Node?= null
    for(i in arr){
        root = insert(root,i)
        println(i)
    }
    
    return root
}

fun insert(root:Node?,value : Int) :Node?{
    // if null make it root
    if(root == null) return Node(value)
    // if left than root place it on left of root else on right
    if(value < root.data){
        root.left = insert(root.left,value)
    }else{
        root.right = insert(root.right,value)
    }
    
    return root
}

fun inorder(root:Node?){
    if(root == null) return
    inorder(root.left)
    print("${root.data}")
    inorder(root.right)
    
}

class Node(val data:Int){
    var left :Node? = null
    var right :Node? = null
}
